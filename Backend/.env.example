# Backend environment variables
# Copy to .env and fill values

# MongoDB connection URL (example: mongodb://127.0.0.1:27017)
MONGO_URL=

# Server
PORT=5000

# Admin account (used by admin login fallback)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123

# JWT secret for admin tokens
JWT_SECRET=change_this_secret

# SMTP settings for sending contact form emails
# Example (Gmail SMTP with App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional: recipient for contact form messages (defaults to ADMIN_EMAIL)
MAIL_TO=

# Twilio (SMS) - used for OTP and confirmation SMS
# If not set, SMS will be logged to the server console (development fallback).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
